model User {
  id String @id @default(uuid())

  // -----------Identity-----------
  name            String?
  email           String     @unique
  password        String
  phoneNumber     String?    @unique
  // Settings
  role            UserRole   @default(employee)
  status          UserStatus @default(ACTIVE)
  isVerified      Boolean    @default(false)
  isOnline        Boolean    @default(false)
  isPhoneVerified Boolean    @default(false)
  // Activity
  lastLoginAt     DateTime?
  lastActiveAt    DateTime?

  // Notifications & Auth
  notifications UserNotification[]
  refreshTokens RefreshToken[]
  otps          UserOtp[]

  // Calling relations
  hostedCalls   Calling[] @relation("HostedCalls")
  receivedCalls Calling[] @relation("ReceivedCalls")

  // profile photo relation
  profilePhoto String?

  subscription            Subscription?
  // ------------ notification toggle -----------
  notificationToggle      NotificationToggle?
  CustomOfferSubscription CustomOfferSubscription[]

  // Chat system
  messages        LiveMessage[]
  chatParticipant LiveChatParticipant[]
  createdChats    LiveChat[]            @relation("LiveChatCreator")
  messageReads    LiveMessageRead[]

  // ---------------- Timestamps --------------------
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @default(now()) @updatedAt

  @@index([email, phoneNumber, name])
  @@map("users")
}

enum UserRole {
  admin
  employer
  employee
}

enum UserStatus {
  ACTIVE
  INACTIVE
  DELETED
}
